{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LoomLess (alpha)",
  "mainBinaryName": "LoomLess",
  "version": "0.0.1",
  "identifier": "com.loomless.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "LoomLess (alpha): Local Screen Recorder",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/camera-overlay"],
    "macOS": {
      "signingIdentity": "-",
      "entitlements": "./Entitlements.plist"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc2Q0M4MERBRjQ3QTAzMzcKUldRM0EzcjAyb0RNZGh0UjdPaWo4SGtWeTI4QllMV1o0MGovd3QyNHN4WC91SElPZTIvUHo1ZUwK",
      "endpoints": [
        "https://github.com/moayaan1911/loomless/releases/latest/download/latest.json"
      ]
    }
  }
}
