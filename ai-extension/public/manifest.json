{
  "manifest_version": 3,
  "name": "LoomLess AI",
  "version": "0.3.0",
  "description": "Minimalist AI companion extension",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "LoomLess AI",
    "default_popup": "index.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://integrate.api.nvidia.com/*",
    "https://ai.api.nvidia.com/*",
    "https://api.tavily.com/*",
    "https://*.supabase.co/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["icon.png"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["icon-map.js", "content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
